term=g.func.find(context.computer.File(""/""),""Terminal.exe"",""b"").push(null)[0]
if term!=null then
context.shell.launch(term.path)
else
print(g.const.indent+g.y1(""Falling back to start_terminal...""))
context.shell.start_terminal
end if
end function
