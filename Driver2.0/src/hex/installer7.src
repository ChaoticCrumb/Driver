return 1
end function
scanAllPorts=function(ip)
idx=g.context.index
if g.hasIndex(""proxy"") and g.proxy!="""" and typeof(g.proxy.to_int)==""number"" and not is_lan_ip(ip) then
idx=g.proxy
print(g.g1(g.const.indent+""Using proxy: ""+g.stack[idx].public))
end if
if not g.func.checkShell(idx) then return 0
if not g.func.checkMetax(idx) then return 0
