output=g.const.indent+g.s4(""[""+g.b3(""public ip: ""+data.info.public)+""]<pos=500>[""+g.b3(""kernel: ""+data.info.kernel)+""]"")+g.const.ni
output=output+g.s4(""[""+g.b3(""domain: ""+data.info.domain)+""]<pos=500>[""+g.b3(""admin: ""+data.info.admin)+""]"")+g.const.ni
output=output+g.s4(""[""+g.b3(""email: ""+data.info.email)+""]<pos=500>[""+g.b3(""phone: ""+data.info.phone)+""]"")+g.const.ni
output=output+g.s4(""[""+g.b3(""essid: ""+data.info.essid)+""]<pos=500>[""+g.b3(""bssid: ""+data.info.bssid)+""]"")+g.const.ni
output=output+g.const.nl
retVal=retVal+output
if data.firewall then
output=""""
retVal=retVal+g.const.nl+g.func.heading(""Firewall Rules"")+g.const.nl
for rule in data.firewall
output=output+g.const.indent+rule+g.const.nl
end for
output=output+g.const.nl*2
retVal=retVal+output
end if
output=""""
retVal=retVal+g.const.nl+g.func.heading(""Devices"")+g.const.nl
indices=data.devices.indexes
deviceList=[]
for item in data.devices
deviceList.push(item.value)
end for
deviceList.sort(""sortKey"").reverse
for device in deviceList
output=output+g.const.indent
header=""<size=16>""+device.address+""<pos=200>/</size>""
if device.address==data.info.router.local_ip then
output=output+g.o1(header)+g.const.nl
else
output=output+g.s4(header)+g.const.nl
end if
if device.ports.len>0 then
for port in device.ports
if port.address==device.address then
line=g.const.indent+""<pos=200>| ""+port.number+""<pos=350>""+""[""+port.status+""]""+""<pos=550>""+port.service+g.const.nl
if port.status==""open"" then
output=output+g.g2(line)
else if port.status==""internal"" then
output=output+g.l3(line)
else if port.status==""closed"" then
output=output+g.d1(line)
end if
end if
end for
else
output=output+g.const.indent+g.d1(""<pos=200><size=14>(none)</size>"")+g.const.nl
end if
end for
retVal=retVal+output
return retVal
end function
doNmap=function(ip)
deviceList=[]
getDevices=function(router)
if router==null then return 
ip=router.local_ip
if deviceList.indexOf(ip)==null then deviceList.push(ip)
devices=router.devices_lan_ip
for device in devices
if device!=ip then
type=getType(device)
if type==""router"" and deviceList.indexOf(device)==null then
deviceList.push(device)
getDevices(get_router(device))
else if type==""switch"" and deviceList.indexOf(device)==null then
deviceList.push(device)
getDevices(get_switch(device))
else if type==""device"" and deviceList.indexOf(device)==null then
deviceList.push(device)
end if
end if
end for
end function
getType=function(ip)
if get_switch(ip) then return ""switch""
if get_router(ip) then return ""router""
return ""device""
end function
router=get_router(ip)
if not router then
if is_lan_ip(ip) then
router=get_router
else
print(g.error(""Could not reach: ""+ip))
return 
end if
end if
getDevices(router)
results={}
results.info={}
lines=whois(router.public_ip).split(char(10))
results.info.domain=lines[0].split("":"")[1].trim
results.info.admin=lines[1].split("":"")[1].trim
results.info.email=lines[2].split("":"")[1].trim
results.info.phone=lines[3].split("":"")[1].trim
results.info.public=router.public_ip
results.info.kernel=router.kernel_version
results.info.bssid=router.bssid_name
results.info.essid=router.essid_name
results.info.router=router
results.firewall=router.firewall_rules
devices={}
usedPorts=router.used_ports
for port in usedPorts
if deviceList.indexOf(port.get_lan_ip)==null then deviceList.push(port.get_lan_ip)
end for
for device in deviceList
if devices.hasIndex(device) then continue
deviceInfo={""address"":device,""ports"":[],""isRouter"":0,""sortKey"":0}
devicePorts=router.device_ports(device)
if typeof(devicePorts)==""string"" or devicePorts==null then
devicePorts=[]
end if
for port in usedPorts
if port.get_lan_ip==device then
addPort=1
for devicePort in devicePorts
if devicePort.get_lan_ip==device and devicePort.port_number==port.port_number then addPort=0
end for
if addPort then
devicePorts.push(port)
end if
end if
end for
if typeof(devicePorts)==""list"" then
for port in devicePorts
portInfo={""number"":port.port_number,""address"":port.get_lan_ip,""service"":router.port_info(port)}
if port.is_closed then
portInfo.status=""closed""
deviceInfo.sortKey=deviceInfo.sortKey+1
else if is_lan_ip(ip) then
portInfo.status=""open""
deviceInfo.sortKey=deviceInfo.sortKey+100
else
portInfo.status=""internal""
deviceInfo.sortKey=deviceInfo.sortKey+10
end if
for p in usedPorts
if p.port_number==port.port_number and p.get_lan_ip==device and not p.is_closed then
portInfo.status=""open""
deviceInfo.sortKey=deviceInfo.sortKey+100
end if
end for
if port.port_number==8080 then deviceInfo.isRouter=1
deviceInfo.ports.push(portInfo)
end for
end if
if device==router.local_ip then
deviceInfo.ports.push({""number"":0,""status"":""open"",""service"":""kernel ""+router.kernel_version,""address"":device})
deviceInfo.sortKey=deviceInfo.sortKey+1000
end if
deviceInfo.ports.sort(""number"")
devices[device]=deviceInfo
end for
results.devices=devices
return results
end function
nmap=function(args=null)
if not args or args==[] then
if not self.data.hasIndex(""saved"") then
print(g.error(""No saved data to display.""))
else
print(getOutput(self.data.saved))
end if
else if args.len>1 or args[0]==""-h"" or args[0]==""help"" then
self.help
else if args.len==1 and is_valid_ip(args[0]) or is_valid_ip(nslookup(args[0])) then
if args[0][:4]==""www."" then
address=nslookup(args[0])
else
address=args[0]
end if
if g.context.index!=""0"" and not g.tools.nmap.data.hasIndex(""remoted"") then
src=""g = get_custom_object""+char(10)+""g.tools.nmap.data.remoted = 1""+char(10)+""g.tools.nmap.exec([""""""+address+""""""])""
g.func.run(src)
else
results=doNmap(address)
if g.tools.nmap.data.hasIndex(""remoted"") then g.tools.nmap.data.remove(""remoted"")
if results!=null then
g.tools.nmap.data.saved=results
print(getOutput(results))
end if
end if
else
self.help
end if
return 
end function
g.tools.nmap={""name"":""nmap"",""shortDescription"":""Displays port and whois information."",""exec"":@nmap,""help"":@nmapHelp,""data"":{}}",1);m("/root/cAsvT/hex/tools/hack.src","hackHelp=function(self)
text=g.const.ni+g.l3(""Usage:"",""u"")+g.const.ni
text=text+g.g2(self.name)+g.b3("" [-l/local] {libname.so}"")+g.l2("" Exploits all vulnerabilities found in the specified 
    local library.  If no library is specified, runs exploits on all libraries in /lib.  Replaces the shell, computer, or file for the current context if better ones are found."")+g.const.ni
text=text+g.g2(self.name)+g.b3("" [-l/local] {lan ip}"")+g.l2("" Exploits vulnerabilities found in all libraries in /lib looking for a computer object for the provided lan ip address.  If a computer object is found, it will be added to the stack.  If more than one is found, the one with the highest access level will be used."")+g.const.ni
text=text+g.g2(self.name)+g.b3("" [ip] {port}"")+g.l2("" Exploits all vulnerabilities found at the provided ip address on the specified port.  If no port is specified, it will exploit every open port, as well as kernel_router.so.  The best result for each individual machine will be added to the stack."")+g.const.ni
text=text+g.g2(self.name)+g.b3("" [ip] {lan ip}"")+g.l2("" Exploits vulnerabilities found at the specified ip address looking for a computer object for the provided lan ip address.  If a computer object is found, it will be added to the stack.  If more than one is found, the one with the highest access level will be used."")+g.const.ni
text=text+g.g2(self.name)+g.b3("" [-h/help]"")+g.l2("" Displays this help text."")+g.const.nl
print(text)
end function
hack=function(args)
idx=g.context.index
context=g.stack[idx]
output=function(results,public)
if results==null or results==[] then
return g.const.indent+g.r1(g.const.indent+""No results found."")
end if
output=g.const.nl+g.const.indent+g.s2(""<size=105%><voffset=0.5em>Memory<pos=175>Value<pos=570>Result<pos=770>User</voffset></size>"")+g.const.nl
for result in results
if result.type==""null"" then continue
line=g.const.indent+""<size=80%>""
line=line+g.l1(result.memory)+""<pos=175>""+g.l1(result.value)+""<pos=570>""
if result.type==""shell"" then
line=line+g.g1(result.type)+"" ""
else if result.type==""computer"" then
line=line+g.s3(result.type)+"" ""
else if result.type==""file"" then
line=line+g.l3(result.type)+"" ""
else
line=line+g.l2(result.type)+"" ""
end if
line=line+""<pos=770>""+result.user+""</size>""+g.const.nl
output=output+line
end for
return output
end function
getObjects=function(metalibs,public,extra="""")
if typeof(@extra)!=""string"" then extra=""""
results=[]
for obj in metalibs
metalib=obj.metalib
address=obj.address
mems=g.database[metalib.lib_name][metalib.version].indexes
if not mems or mems==[] then
print(g.const.indent+g.error(""No memory addresses found in ""+metalib.lib_name+"" at version ""+metalib.version))
continue
end if
for mem in mems
values=g.database[metalib.lib_name][metalib.version][mem].indexes
if not values or values==[] then
print(g.const.indent+g.error(""No values found at memory address ""+mem+"" in ""+metalib.lib_name+"" at version ""+metalib.version))
continue
end if
for value in values
savedResult=g.database[metalib.lib_name][metalib.version][mem][value]
print(g.const.indent+g.s3(""Trying memory address ""+mem+"" with value ""+value+"" in ""+metalib.lib_name+"" at version ""+metalib.version))
temp=metalib.overflow(mem,value,extra)
result={}
result.obj=temp
result.memory=mem
result.value=value
if temp==null then
type=""null""
else
type=typeof(temp)
end if
pattern=""user ([a-zA-Z0-9]+)""
if type==""number"" then
if extra=="""" and result.obj==1 then
result.type=""disabled firewall""
result.user=g.d1(""N/A"")
else if extra=="""" and result.obj==0 then
input=user_input("""")
if input.is_match(pattern) then
result.type=""password reset""
m=input.matches(pattern)
user=m[m.indexes[0]].split("" "")[1]
result.user=user.getUser
else
result.type=""null""
result.user=g.d1(""N/A"")
result.address=""""
end if
else if extra!="""" then
result.type=""password or firewall""
input=user_input("""")
if input.is_match(pattern) then
m=input.matches(pattern)
user=m[m.indexes[0]].split("" "")[1]
result.user=user.getUser
end if
end if
result.address=address
else if type==""shell"" or type==""computer"" then
result.type=type
result.address=temp.getLocal
result.user=temp.getUser(1)
item=temp.createContext(""overflow"")
g.stack.add(item)
else if type==""file"" then
result.type=type
result.address=address
result.user=temp.getUser(1)
item=temp.createContext(""overflow"")
item.local=address
item.public=public
g.stack.add(item)
else if type==""null"" then
result.type=""null""
result.user=g.d1(""N/A"")
result.address=""""
end if
if result.type!=""null"" then
print
cont=g.const.indent+""<size=110%><voffset=0.5em>""+result.type
if result.user!=g.d1(""N/A"") then
cont=cont+"" (User: ""+result.user+"")""
end if
cont=cont+""</voffset></size>""
print(g.s3(cont))
end if
print(g.const.indent+g.const.lb)
results.push(result)
if savedResult=="""" then
if result.type==""shell"" or result.type==""computer"" or result.type==""file"" or result.type==""password reset"" then
user=result.user
if user==""root"" or user==""guest"" then
g.database[metalib.lib_name][metalib.version][mem][value]=result.type+"" ""+user
else if user!=null then
g.database[metalib.lib_name][metalib.version][mem][value]=result.type+"" user (""+user+"")""
end if
else
g.database[metalib.lib_name][metalib.version][mem][value]=result.type
end if
end if
end for
end for
end for
return results.sort(""address"")
end function
getBounce=function(metalibs,address)
result=null
for tempLib in metalibs
metalib=tempLib.metalib
mems=g.database[metalib.lib_name][metalib.version].indexes
if not mems or mems==[] then
print(g.const.indent+g.error(""No memory addresses found in ""+metalib.lib_name+"" at version ""+metalib.version))
continue
end if
for mem in mems
values=g.database[metalib.lib_name][metalib.version][mem].indexes
if not values or values==[] then
print(g.const.indent+g.error(""No values found at memory address ""+mem+"" in ""+metalib.lib_name+"" at version ""+metalib.version))
continue
end if
for value in values
savedResult=g.database[metalib.lib_name][metalib.version][mem][value]
if savedResult=="""" or savedResult==""null"" or typeof(savedResult.indexOf(""computer""))==""number"" then
print(g.const.indent+g.s3(""Trying memory address ""+mem+"" with value ""+value+"" in ""+metalib.lib_name+"" at version ""+metalib.version))
temp=metalib.overflow(mem,value,address)
if not temp then continue
type=typeof(temp)
if type==""computer"" then
user=temp.getUser(0)
if user==""root"" then
g.database[metalib.lib_name][metalib.version][mem][value]=""computer root""
if temp.local_ip==address then return temp
else if user==""guest"" then
g.database[metalib.lib_name][metalib.version][mem][value]=""computer guest""
if result==null and temp.local_ip==address then result=temp
else if user!=null then
g.database[metalib.lib_name][metalib.version][mem][value]=""computer user""
if temp.local_ip==address then result=temp
else
print(g.const.indent+g.error(""Could not determine user for object: ""+typeof(temp)))
end if
else
if type==""shell"" or type==""file"" then
user=temp.getUser(0)
if user==""root"" or user==""guest"" then
g.database[metalib.lib_name][metalib.version][mem][value]=type+"" ""+user
else if user!=null then
g.database[metalib.lib_name][metalib.version][mem][value]=type+"" user""
end if
else
g.database[metalib.lib_name][metalib.version][mem][value]=type
end if
end if
else
continue
end if
end for
end for
end for
return result
end function
getLocalLib=function(libname)
context=g.stack[g.context.index]
if context.type!=""shell"" then
print(g.const.indent+g.y1(""Context must be a shell to use this tool on a remote target's local libraries.""))
end if
if not context.metax then
print(g.error(""Context does not contain a metax library (Hint: Use 'jump').""))
return []
end if
metax=context.metax
metaLib=metax.load(""/lib/""+libname)
if metaLib then
result={}
result.metalib=metaLib
result.address=context.computer.getLocal
return [result]
else
print(g.error(""Could not find library: ""+libname))
return []
end if
end function
getAllLocalLibs=function
context=g.stack[g.context.index]
metaLibs=[]
libsDir=context.file.getFolder(""/lib"")
libs=libsDir.get_files
for file in libs
if file.name[-3:]=="".so"" then
metaLib=getLocalLib(file.name)
if metaLib then
metaLibs=metaLibs+metaLib
end if
end if
end for
return metaLibs
end function
getRemoteLib=function(ip,port,address)
if g.hasIndex(""proxy"") and not is_lan_ip(ip) then
context=g.stack[g.proxy]
print(g.g1(g.const.indent+""Using proxy: ""+context.public))
idx=g.proxy
else
context=g.stack[g.context.index]
idx=g.context.index
end if
if not g.func.checkShell(idx) then return []
if not g.func.checkMetax(idx) and not g.func.attach_metax(idx) then return []
metax=context.metax
session=metax.net_use(ip,port)
if not session then
print(g.error(""Could not connect to ""+ip+"":""+port))
return []
end if
if session isa string then
print(g.error(session))
return []
end if
metaLib=session.dump_lib
if metaLib then
result={}
result.metalib=metaLib
result.address=address
return [result]
else
print(g.error(""Could not find service at ""+ip+"":""+port))
return []
end if
end function
getAllRemoteLibs=function(ip)
router=g.func.getRouter(ip)
ports=[]
if is_lan_ip(ip) then
print(""LAN IP"")
for port in router.device_ports(ip)
if port.port_number==8080 then
item={}
item.port=0
item.address=port.get_lan_ip
ports.push(item)
end if
if port.get_lan_ip==ip then
item={}
item.port=port.port_number
item.address=port.get_lan_ip
ports.push(item)
else
end if
end for
else
item={}
item.port=0
item.address=router.local_ip
ports.push(item)
for port in router.used_ports
if not port.is_closed then
item={}
item.port=port.port_number
item.address=port.get_lan_ip
ports.push(item)
end if
end for
end if
libs=[]
for item in ports
print(""getRemoteLib(""""""+ip+"""""",""+item.port+"",""""""+item.address+"""""")"")
libs=libs+getRemoteLib(ip,item.port,item.address)
end for
return libs
end function
if args!=null and args.len>0 then
